# Discord 봇 토큰 — https://discord.com/developers/applications 에서 발급
DISCORD_TOKEN=your_discord_bot_token_here

# 봇 명령을 사용할 수 있는 디스코드 역할 이름
ADMIN_ROLE=Minecraft Admin

# RCON 비밀번호 — 봇이 마인크래프트 컨테이너에 명령(/sayall, /tps)을 보낼 때 사용
# 외부 노출은 안 되지만(network 내부 통신) 강한 값으로 바꾸세요
RCON_PASSWORD=change-this-to-a-strong-password

# (선택) 마인크래프트 서버 공개 도메인 — /list, /status 응답에 표시됨
# PUBLIC_HOST=server.example.com
